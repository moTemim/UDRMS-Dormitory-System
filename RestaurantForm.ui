       <property name="styleSheet">
        <string notr="true">QGroupBox {
    /* Bold dark green border with rounded corners */
    border: 2px solid #2d6a2d;
    border-radius: 8px;
    
    /* Pushes the interior content down so it doesn't overlap the title */
    margin-top: 14px;
    padding-top: 15px;
    padding-left: 10px;
    padding-right: 10px;
    
    /* Header text formatting */
    font-weight: bold;
    font-size: 13px;
    color: #2d6a2d;
    
    /* Clean, soft off-white/cream background to pop against the dark workspace */
    background-color: #f7faf6;
}

/* Position and style the text title anchor on the top line */
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 12px;
    padding-left: 6px;
    padding-right: 6px;
    
    /* Matches the parent container's solid background color to cut through the border line cleanly */
    background-color: #f7faf6; 
}</string>
       </property>
