     <property name="styleSheet">
      <string notr="true">QTabWidget::pane {
    border: 2px solid #2d6a2d;
    border-radius: 8px;
    background-color: rgba(255,255,255,180);
    padding: 5px;
}

QTabBar::tab {
    padding: 10px;
    border-bottom: 1px solid #a0d0a0;
    color: #1a3d1a;
    font-size: 14px;
    background-color: rgba(255,255,255,180);
    
    /* ADDED: This creates a subtle green separator line on the right side of each tab */
    border-right: 1px solid #a0d0a0; 
}

/* ADDED: Removes the separator line from the last tab so it looks professional */
QTabBar::tab:last {
    border-right: none;
}

QTabBar::tab:selected {
    background-color: #2d6a2d;
    color: white;
    border-radius: 5px;
    /* ADDED: Keeps the separator invisible on the right side when selected so the button looks clean */
    border-right: none; 
}

QTabBar::tab:hover {
    background-color: #c8e6c8;
    border-radius: 5px;
}</string>
