   <property name="styleSheet">
    <string notr="true">/* Style the main closed dropdown box */
QComboBox {
    border: 1px solid #2d6a2d;
    border-radius: 4px;
    padding: 4px 10px;
    min-width: 6em;
    color: #1a3d1a;
    background-color: rgba(255, 255, 255, 210);
    font-size: 20px;
}

/* Style the arrow button section box on the right side */
QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 25px; /* Widened slightly for click breathing room */
    border-left-width: 1px;
    border-left-color: #a0d0a0;
    border-left-style: solid; 
    border-top-right-radius: 4px; 
    border-bottom-right-radius: 4px;
}

/* FIX: This explicitly draws a sharp down-arrow triangle inside the dropdown area */
QComboBox::down-arrow {
    image: none; /* Clear native windows images */
    border-left: 5px solid transparent;
    border-right: 5px solid transparent;
    border-top: 6px solid #2d6a2d; /* Draws a sharp green triangle down arrow */
    width: 0;
    height: 0;
    position: relative;
    right: 2px; /* Centers it nicely inside the 25px area */
}

/* Style the popup list box that drops down when clicked */
QComboBox QAbstractItemView {
    border: 1px solid #2d6a2d;
    background-color: #ffffff;
    selection-background-color: #2d6a2d;
    selection-color: white;
    color: #1a3d1a;
}</string>
